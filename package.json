{
  "name": "chaos-league",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:dev:status": "dotenv -e .env.development -- prisma migrate status",
    "prisma:dev:generate": "dotenv -e .env.development -- prisma generate",
    "prisma:dev:migrate": "dotenv -e .env.development -- prisma migrate dev",
    "prisma:dev:reset": "dotenv -e .env.development -- prisma migrate reset --force",
    "prisma:prod:status": "dotenv -e .env.production -- prisma migrate status",
    "prisma:prod:generate": "dotenv -e .env.production -- prisma generate",
    "prisma:prod:deploy": "dotenv -e .env.production -- prisma migrate deploy",
    "db:dev:reset": "npm run prisma:dev:reset",
    "db:prod:deploy": "npm run prisma:prod:deploy",
    "seed:2025": "dotenv -e .env.development -- tsx prisma/seed-2025.ts",
    "seed:dev2025": "dotenv -e .env.development -- tsx prisma/seed-dev.ts",
    "seed:all": "dotenv -e .env.development -- prisma db seed",
    "replay:2025:r64": "dotenv -e .env.development -- tsx prisma/replay-2025.ts --round=R64",
    "replay:2025:r32": "dotenv -e .env.development -- tsx prisma/replay-2025.ts --round=R32",
    "replay:2025:s16": "dotenv -e .env.development -- tsx prisma/replay-2025.ts --round=S16",
    "replay:2025:e8": "dotenv -e .env.development -- tsx prisma/replay-2025.ts --round=E8",
    "replay:2025:f4": "dotenv -e .env.development -- tsx prisma/replay-2025.ts --round=F4",
    "replay:2025:ncg": "dotenv -e .env.development -- tsx prisma/replay-2025.ts --round=NCG",
    "import:2025:r64": "dotenv -e .env.development -- tsx prisma/import-results-2025.ts --round R64",
    "import:2025:r32": "dotenv -e .env.development -- tsx prisma/import-results-2025.ts --round R32",
    "import:2025:s16": "dotenv -e .env.development -- tsx prisma/import-results-2025.ts --round S16",
    "import:2025:e8": "dotenv -e .env.development -- tsx prisma/import-results-2025.ts --round E8",
    "import:2025:f4": "dotenv -e .env.development -- tsx prisma/import-results-2025.ts --round F4",
    "import:2025:final": "dotenv -e .env.development -- tsx prisma/import-results-2025.ts --round FINAL",
    "smoke": "dotenv -e .env.development -- tsx scripts/smoke-sim.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@vercel/analytics": "^2.0.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "prisma": "^6.19.2",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
