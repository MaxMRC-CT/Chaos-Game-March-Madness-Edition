generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TournamentYear {
  id        String   @id @default(cuid())
  year      Int      @unique
  name      String
  createdAt DateTime @default(now())
  leagues   League[]
  teams     Team[]
}

model Team {
  id               String           @id @default(cuid())
  tournamentYearId String
  name             String
  shortName        String?
  seed             Int
  region           String
  logoUrl          String?
  createdAt        DateTime         @default(now())
  draftPicks       DraftPick[]
  portfolioPicks   PortfolioPick[]
  tournamentYear   TournamentYear   @relation(fields: [tournamentYearId], references: [id])
  teamResults      TeamResult[]
  lostGames        TournamentGame[] @relation("LoserTeam")
  wonGames         TournamentGame[] @relation("WinnerTeam")

  @@index([tournamentYearId])
  @@index([tournamentYearId, seed])
}

model League {
  id                      String                @id @default(cuid())
  tournamentYearId        String
  name                    String
  code                    String                @unique
  status                  LeagueStatus          @default(SETUP)
  currentPick             Int                   @default(0)
  createdAt               DateTime              @default(now())
  championshipTotalPoints Int?
  /// Optional: when set, league auto-locks at this time if still SETUP. Eastern Time semantics.
  lockDeadline            DateTime?
  /// Optional: first tournament tip-off (Eastern). LIVE threshold = firstTipOff - 60min when set.
  firstTipOff             DateTime?
  picks                   DraftPick[]
  tournamentYear          TournamentYear        @relation(fields: [tournamentYearId], references: [id])
  events                  LeagueEvent[]
  members                 LeagueMember[]
  score                   LeagueScore?
  scoreSnapshots          LeagueScoreSnapshot[]
  portfolioPicks          PortfolioPick[]
  teamResults             TeamResult[]
  tournamentGames         TournamentGame[]
}

model LeagueMember {
  id                     String          @id @default(cuid())
  leagueId               String
  nickname               String
  isAdmin                Boolean         @default(false)
  draftPosition          Int?
  createdAt              DateTime        @default(now())
  displayName            String
  nicknameKey            String
  deviceToken            String?
  reconnectCode          String          @unique
  championshipPrediction Int?
  picks                  DraftPick[]
  league                 League          @relation(fields: [leagueId], references: [id])
  portfolioPicks         PortfolioPick[]

  @@unique([leagueId, nicknameKey])
  @@index([leagueId])
}

model DraftPick {
  id         String       @id @default(cuid())
  leagueId   String
  memberId   String
  teamId     String
  pickNumber Int
  createdAt  DateTime     @default(now())
  role       DraftRole
  league     League       @relation(fields: [leagueId], references: [id])
  member     LeagueMember @relation(fields: [memberId], references: [id])
  team       Team         @relation(fields: [teamId], references: [id])

  @@unique([leagueId, memberId, role])
  @@unique([leagueId, teamId])
  @@unique([leagueId, pickNumber])
  @@index([leagueId])
  @@index([memberId])
}

model TournamentGame {
  id           String   @id @default(cuid())
  leagueId     String
  round        Round
  gameNo       Int
  winnerTeamId String
  loserTeamId  String
  createdAt    DateTime @default(now())
  league       League   @relation(fields: [leagueId], references: [id])
  loser        Team     @relation("LoserTeam", fields: [loserTeamId], references: [id])
  winner       Team     @relation("WinnerTeam", fields: [winnerTeamId], references: [id])

  @@unique([leagueId, round, gameNo])
  @@index([leagueId])
}

model TeamResult {
  id              String   @id @default(cuid())
  leagueId        String
  teamId          String
  wins            Int      @default(0)
  eliminatedRound Round?
  updatedAt       DateTime @updatedAt
  league          League   @relation(fields: [leagueId], references: [id])
  team            Team     @relation(fields: [teamId], references: [id])

  @@unique([leagueId, teamId])
  @@index([leagueId])
}

model LeagueScore {
  id        String   @id @default(cuid())
  leagueId  String   @unique
  updatedAt DateTime @updatedAt
  totals    Json
  league    League   @relation(fields: [leagueId], references: [id])
}

model LeagueScoreSnapshot {
  id        String   @id @default(cuid())
  leagueId  String
  createdAt DateTime @default(now())
  totals    Json
  league    League   @relation(fields: [leagueId], references: [id])

  @@index([leagueId, createdAt])
}

model LeagueEvent {
  id        String   @id @default(cuid())
  leagueId  String
  type      String
  payload   Json
  createdAt DateTime @default(now())
  league    League   @relation(fields: [leagueId], references: [id])

  @@index([leagueId, createdAt])
}

model PortfolioPick {
  id        String       @id @default(cuid())
  leagueId  String
  memberId  String
  teamId    String
  role      RoleType
  createdAt DateTime     @default(now())
  league    League       @relation(fields: [leagueId], references: [id])
  member    LeagueMember @relation(fields: [memberId], references: [id])
  team      Team         @relation(fields: [teamId], references: [id])

  @@unique([leagueId, memberId, teamId])
  @@index([leagueId])
  @@index([memberId])
}

enum LeagueStatus {
  SETUP
  LOCKED
  DRAFT
  LIVE
  COMPLETE
}

enum DraftRole {
  HERO
  VILLAIN
  CINDERELLA
}

enum RoleType {
  HERO
  VILLAIN
  CINDERELLA
}

enum Round {
  R64
  R32
  S16
  E8
  F4
  FINAL
  CHAMP
}
